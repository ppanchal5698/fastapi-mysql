# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy async URL using aiomysql driver
DATABASE_URL=mysql+aiomysql://user:password@127.0.0.1:3306/app

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev-only-change-in-production
JWT_ALGORITHM=HS256
